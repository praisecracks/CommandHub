# API Keys - Get your own keys from the respective services
# Calendarific API: https://calendarific.com/
EXPO_PUBLIC_CALENDARIFIC_API_KEY=your_calendarific_api_key_here

# OpenWeather API: https://openweathermap.org/api
EXPO_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here

# News API: https://newsapi.org/
EXPO_PUBLIC_NEWS_API_KEY=your_news_api_key_here

# Firebase Configuration - Get from Firebase Console
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
